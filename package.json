{
  "name": "employee-management-system",
  "private": true,
  "description": "Delegates npm scripts to ems-web. Run npm install inside ems-web first.",
  "scripts": {
    "dev": "npm run dev --prefix ems-web",
    "dev:all": "npm run dev:all --prefix ems-web",
    "dev:api": "npm run dev:api --prefix ems-web",
    "dev:https": "npm run dev:https --prefix ems-web",
    "build:web": "npm run build --prefix ems-web",
    "lint:web": "npm run lint --prefix ems-web"
  }
}
