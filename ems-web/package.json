{
  "name": "ems-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently -n api,web -c cyan,magenta \"dotnet run --project ../EMS.API/EMS.API.csproj --launch-profile http\" \"next dev\"",
    "dev:api": "dotnet run --project ../EMS.API/EMS.API.csproj --launch-profile http",
    "dev:https": "concurrently -n api,web -c cyan,magenta \"dotnet run --project ../EMS.API/EMS.API.csproj --launch-profile https\" \"next dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
