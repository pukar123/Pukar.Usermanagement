{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Enrichers.Environment" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ],
    "Properties": {
      "Application": "EMS.API",
      "Module": "EMS.API"
    },
    "WriteTo": [ { "Name": "Console" } ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "UserManagement": "Server=localhost,1433;Database=EMSDevDB;User Id=sa;Password=Dev123!@#Strong;TrustServerCertificate=True",
    "DefaultConnection": "Server=localhost,1433;Database=EMSDevDB;User Id=sa;Password=Dev123!@#Strong;TrustServerCertificate=True",
    "MongoDb": "mongodb://admin:Dev123%21%40%23Strong@localhost:27017/?authSource=admin",
    "MongoLogs": "mongodb://admin:Dev123%21%40%23Strong@localhost:27017/ems-logs?authSource=admin",
    "Redis": "localhost:6379,password=Dev123!@#Strong"
  },
  "Jwt": {
    "Issuer": "EMS.API",
    "Audience": "EMS.API",
    "SigningKey": "EMS_Dev_Signing_Key_At_Least_32_Chars!!",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "AllowedHosts": "*"
}